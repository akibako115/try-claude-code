# データベース接続URL
# SQLite（デフォルト）:
DATABASE_URL=sqlite+pysqlite:///./papers.db
# PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/papernotes

# JWT署名に使う秘密鍵（本番では必ず長いランダム文字列に変更）
SECRET_KEY=change-me-to-a-long-random-secret-key

# OpenAI API キー（AI要約機能を使う場合）
OPENAI_API_KEY=

# フロントエンドのオリジン（本番では実際のドメインに変更）
FRONTEND_ORIGIN=http://localhost:5173
